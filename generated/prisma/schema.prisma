generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  WEB
  MOBILE
  DESKTOP
}

model Users {
  id Int @id @default(autoincrement())

  name     String
  lastname String
  email    String @unique

  hashedPassword String

  lastlogin DateTime

  auditLogs       AuditLogs[]
  sessions        AuthSession[]
  loginSecurities LoginSecurity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthSession {
  id String @id

  userId Int
  user   Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshHash String

  deviceType DeviceType
  deviceName String?

  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime

  @@index([userId])
}

model AuditLogs {
  id Int @id @default(autoincrement())

  userId Int
  user   Users? @relation(references: [id], fields: [userId])

  action String

  ipAddress String?

  metadata String?

  createdAt DateTime @default(now())
}

model LoginSecurity {
  id Int @id @default(autoincrement())

  userId Int
  user   Users? @relation(references: [id], fields: [userId])

  failedCount Int @default(0)

  lockedUntil DateTime?

  strike Int @default(0)

  updatedAt DateTime @updatedAt
}
